{
  "crons": [
    {
      "path": "/api/cron/ingest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/analytics-sync",
      "schedule": "0 6 * * *"
    }
  ],
  "headers": [
    {
      "source": "/favicon.ico",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/icon-32.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/icon-48.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/icon-192.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/apple-touch-icon.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/apple-touch-icon-precomposed.png",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/safari-pinned-tab.svg",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "gtavihub.gg" }],
      "destination": "https://www.gtavihub.gg/",
      "permanent": true
    },
    {
      "source": "/:path((?!favicon\\.ico$|favicon\\.svg$|icon-32\\.png$|icon-48\\.png$|icon-192\\.png$|apple-touch-icon\\.png$|apple-touch-icon-precomposed\\.png$|safari-pinned-tab\\.svg$).+)",
      "has": [{ "type": "host", "value": "gtavihub.gg" }],
      "destination": "https://www.gtavihub.gg/:path",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "gta6hub-five.vercel.app" }],
      "destination": "https://www.gtavihub.gg/:path*",
      "permanent": true
    }
  ]
}
